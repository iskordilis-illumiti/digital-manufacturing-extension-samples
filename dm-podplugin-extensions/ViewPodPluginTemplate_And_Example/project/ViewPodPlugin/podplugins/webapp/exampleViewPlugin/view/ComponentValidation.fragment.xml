<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:table="sap.ui.table"
>
    <Dialog title="Validate Components" id="dcomponentValidator" escapeHandler=".onValDEscape">
        
           
       

        <Table
            id="Vcomp"
            width="50%"
            items="{
                            path: '/components'
                        }"
        >
         <headerToolbar>
                <Toolbar>
                 <Label text="Enter or Scan component"  width="35%"/>
            <Input id="componentInput" submit="onEnterPressed" width="35%"/>
            <Button
                text="Validate"
                type="Emphasized"
                press="onValidateComponent"
                
            />
                </Toolbar>
                </headerToolbar>

            <columns>
                <Column>
                    <Text text='Components' />
                </Column>
                <Column>
                    <Text text="Description" />
                </Column>
                <Column>
                    <Text text="Validated" />
                </Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{component}" />
                        <Text text="{description}" />
                        <Text text="{validated}" />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Dialog>
</core:FragmentDefinition>
